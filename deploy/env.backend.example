# ============================================================
# Backend - OxxPharma .env (PRODUCAO)
# ============================================================
# Copie este arquivo para /var/www/oxxpharma/backend/.env e edite

# --- Banco ---
MONGO_URL=mongodb://localhost:27017
DB_NAME=oxxpharma

# --- Seguranca ---
# IMPORTANTE: troque por uma chave aleatoria de 64 caracteres em producao!
# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=TROQUE_POR_UMA_CHAVE_ALEATORIA_DE_64_CARACTERES_AQUI

# --- Admin inicial ---
ADMIN_EMAIL=admin@oxxpharma.com
ADMIN_PASSWORD=TROQUE_ESTA_SENHA_NO_PRIMEIRO_LOGIN

# --- MercadoPago ---
# OBSERVACAO: As credenciais MP podem ser configuradas via painel admin (DB).
# Os valores abaixo servem como FALLBACK caso o DB esteja vazio.
# Recomendado: deixe vazio aqui e configure tudo pelo painel /backoffice/pagamentos
MP_PUBLIC_KEY_TEST=
MP_ACCESS_TOKEN_TEST=
MP_PUBLIC_KEY_PROD=
MP_ACCESS_TOKEN_PROD=
MP_WEBHOOK_SECRET=

# --- URL publica do app (sem barra final) ---
# Usado em emails, links de reset, redirects do MP, etc
APP_URL=https://oxxpharma.com.br
BACKEND_URL=https://oxxpharma.com.br
